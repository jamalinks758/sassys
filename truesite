<script>
  // ===== AOS INIT =====
  AOS.init({ once: true, duration: 700, easing: 'ease-out-quad' });

  // ===== THEME SWITCHER =====
  function setTheme(t) {
    document.body.className = 'theme-' + t;
  }

  // ===== WHATSAPP AUTO-REPLY ORDER =====
  function orderWhatsApp(product) {
    const msg = encodeURIComponent(
      `Hi Sassy's Wellness Juicery! 🥤\n\nI'd like to order: *${product}*\n\nPlease let me know available sizes and your earliest delivery time. Thank you! 🌿`
    );
    window.open(`https://wa.me/17584869001?text=${msg}`, '_blank');
  }

  // ===== PAYPAL PRODUCT-SPECIFIC =====
  function paypal(product, amount) {
    const base = 'https://www.paypal.com/paypalme/sassyswellnessjuicery/';
    const note = encodeURIComponent(`Sassy's Order: ${product}`);
    window.open(`${base}${amount}`, '_blank');
    // After opening, show confirmation tip
    setTimeout(() => {
      alert(`💳 PayPal opened for: ${product} ($${amount})\n\nAfter payment, please WhatsApp your receipt to 758-486-9001 to confirm your order. Thank you! 🧃`);
    }, 800);
  }

  // ===== COUNTDOWN TIMER =====
  function startTimer() {
    const el = document.getElementById('offerTimer');
    if (!el) return;
    let totalSecs = 23 * 3600 + 59 * 60 + 30;
    setInterval(() => {
      totalSecs = Math.max(0, totalSecs - 1);
      const h = String(Math.floor(totalSecs / 3600)).padStart(2,'0');
      const m = String(Math.floor((totalSecs % 3600) / 60)).padStart(2,'0');
      const s = String(totalSecs % 60).padStart(2,'0');
      el.textContent = `${h}:${m}:${s}`;
    }, 1000);
  }
  startTimer();

  // ===== STOCK COUNTER ANIMATION =====
  const stockNums = [14, 9, 12, 7, 5, 11, 8];
  let idx = 0;
  setInterval(() => {
    const el = document.getElementById('stock-count');
    if (el && stockNums[idx] > 0) {
      stockNums[idx] = Math.max(0, stockNums[idx] - Math.floor(Math.random() * 1));
    }
    idx = (idx + 1) % stockNums.length;
  }, 8000);

  // ===== SMOOTH SCROLL =====
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const t = document.querySelector(a.getAttribute('href'));
      if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
    });
  });
</script>
